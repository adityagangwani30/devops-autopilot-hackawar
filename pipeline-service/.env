# ─── Pipeline Service Configuration ───────────────────────────────────────────

# Port the service listens on
PORT=3000

# Environment (development | production)
NODE_ENV=development

# ─── Sentry ───────────────────────────────────────────────────────────────────

# HMAC secret from Sentry webhook config
# Leave blank in local dev to skip signature verification
SENTRY_WEBHOOK_SECRET=

# ─── Agent ────────────────────────────────────────────────────────────────────

# URL of your agent service
AGENT_ENDPOINT=http://localhost:4000/handle-error

# Optional bearer token for agent auth
AGENT_API_KEY=

# Timeout waiting for agent response (ms)
AGENT_TIMEOUT_MS=15000

# ─── Slack ────────────────────────────────────────────────────────────────────

# Incoming Webhook URL from your Slack app
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Channel to post alerts into
SLACK_CHANNEL=#alerts

# Timeout for Slack API calls (ms)
SLACK_TIMEOUT_MS=5000

# ─── Filtering ────────────────────────────────────────────────────────────────

# Only process these environments (comma-separated). Empty = allow all.
# ALLOWED_ENVIRONMENTS=production,staging

# Only process these levels (comma-separated)
ALLOWED_LEVELS=error,fatal,critical

# ─── Logging ──────────────────────────────────────────────────────────────────

# Log level: error | warn | info | debug
LOG_LEVEL=info
