# ─── Agent Service Configuration ──────────────────────────────────────────────

# Port this service listens on
AGENT_PORT=4000

# ─── Mode ─────────────────────────────────────────────────────────────────────

# llm  — uses Claude via Anthropic API (requires ANTHROPIC_API_KEY)
# rule — deterministic rule-based analysis (no API key needed, good for testing)
AGENT_MODE=llm

# ─── Anthropic API ────────────────────────────────────────────────────────────

# Your Anthropic API key — get one at console.anthropic.com
# Required when AGENT_MODE=llm
ANTHROPIC_API_KEY=sk-ant-...

# ─── Auth ─────────────────────────────────────────────────────────────────────

# Optional: shared secret between pipeline service and agent
# Must match AGENT_API_KEY in pipeline-service/.env
# Leave blank to disable auth (fine for local dev / internal network)
AGENT_API_KEY=

# ─── Logging ──────────────────────────────────────────────────────────────────

LOG_LEVEL=info
