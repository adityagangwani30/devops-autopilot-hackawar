# ─── Agent Service Configuration ─────────────────────────────────────────────

# Port the agent listens on
AGENT_PORT=4000

# Agent mode: "llm" or "rule"
# llm  — uses Claude via Anthropic API
# rule — deterministic pattern matching (no API key needed)
AGENT_MODE=rule

# Anthropic API key (required only for llm mode)
ANTHROPIC_API_KEY=

# Shared secret for bearer token auth (must match pipeline's AGENT_API_KEY)
AGENT_API_KEY=

# Log level: error | warn | info | debug
LOG_LEVEL=info
