{
  "name": "devops-autopilot-hackawar",
  "private": true,
  "scripts": {
    "setup": "npm run install:all",
    "install:all": "npm --prefix frontend install && npm --prefix backend/github-integration install",
    "dev": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend/github-integration run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "npm --prefix backend/github-integration run build",
    "typecheck": "npm run typecheck:frontend && npm run typecheck:backend",
    "typecheck:frontend": "npm --prefix frontend run typecheck",
    "typecheck:backend": "npm --prefix backend/github-integration run typecheck",
    "start": "node scripts/serve-static.mjs frontend/out 3000",
    "preview": "node scripts/serve-static.mjs frontend/out 3000"
  }
}
